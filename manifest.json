{
  "manifest_version": 3,
  "name": "FloSports Pirate Reporter",
  "version": "3.3.1",
  "key": "",
  "description": "Automated copyright reporting tool with screenshot capabilities.",
  "permissions": [
    "scripting",
    "storage",
    "identity",
    "identity.email",
    "webRequest",
    "downloads",
    "sidePanel",
    "alarms",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://studio.youtube.com/*", 
    "https://www.tiktok.com/*",
    "https://www.youtube.com/*",
    "https://www.instagram.com/*",
    "https://www.facebook.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.twitch.tv/*",
    "https://discord.com/*",
    "https://ipr.tiktokforbusiness.com/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "1077684119158-g9a5ov4qpb40nbnc5rec0i9l8dp2i9us.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive",
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Reporter",
    "default_icon": {
      "16": "FloReporter_logo.png",
      "48": "FloReporter_logo.png",
      "128": "FloReporter_logo.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.tiktok.com/*",
        "*://www.youtube.com/*",
        "*://www.instagram.com/*",
        "*://www.facebook.com/*",
        "*://twitter.com/*",
        "*://x.com/*",
        "*://www.twitch.tv/*",
        "*://discord.com/*",
        "*://timstreams.net/*"
      ],
      "js": ["content_scraper.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "*://studio.youtube.com/*",
        "*://ipr.tiktokforbusiness.com/*",
        "*://www.tiktok.com/legal/report/*",
        "*://www.youtube.com/copyright_complaint_form*",
        "*://help.instagram.com/*",
        "*://help.x.com/*",
        "*://www.facebook.com/help/contact/*"
      ],
      "js": ["content_autofill.js"],
      "run_at": "document_idle", 
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["lib/jspdf.umd.min.js", "style.css", "jingle.mp3", "search_bot.js"],
      "matches": [
        "*://*.tiktok.com/*", 
        "*://*.youtube.com/*", 
        "*://*.instagram.com/*", 
        "*://*.facebook.com/*", 
        "*://twitter.com/*", 
        "*://x.com/*", 
        "*://*.twitch.tv/*", 
        "*://discord.com/*", 
        "*://ipr.tiktokforbusiness.com/*"
      ]
    }
  ]
}